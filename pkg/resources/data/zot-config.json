{
  "distSpecVersion": "1.1.1",
  "storage": {
    "rootDirectory": "/var/lib/zot"
  },
  "http": {
    "address": "0.0.0.0",
    "port": "5000",
    "tls": {
      "cert":"/etc/ssl/localtest.me.crt",
      "key":"/etc/ssl/localtest.me.key"
    }
  },
  "log": {
    "level": "error"
  },
  "extensions": {
    "ui": {
      "enable": true
    },
    "search": {
      "enable": true
    },
    "sync": {
      "enable": true,
      "registries": [
        {
          "urls": [
            "https://registry-1.docker.io"
          ],
          "onDemand": true,
          "content": [
            {
              "prefix": "**"
            }
          ]
        },
        {
          "urls": [
            "https://ghcr.io"
          ],
          "onDemand": true,
          "content": [
            {
              "prefix": "**"
            }
          ]
        },
        {
          "urls": [
            "https://quay.io"
          ],
          "onDemand": true,
          "content": [
            {
              "prefix": "**"
            }
          ]
        },
        {
          "urls": [
            "https://registry.k8s.io"
          ],
          "onDemand": true,
          "content": [
            {
              "prefix": "**"
            }
          ]
        }
      ]
    }
  }
}

