{
  "distSpecVersion": "1.1.1",
  "storage": {
    "rootDirectory": "/var/lib/zot",
    "commit": true,
    "dedupe": true,
    "gc": true
  },
  "http": {
    "address": "0.0.0.0",
    "port": "5000",
    "tls": {
      "cert":"/etc/ssl/localtest.me.crt",
      "key":"/etc/ssl/localtest.me.key"
    }
  },
  "log": {"level": "debug"},
  "extensions": {
    "ui": { "enable": true },
    "search": { "enable": true },
    "sync": {
      "enable": true,
      "registries": [
        {
          "urls": [
            "https://registry-1.docker.io",
            "https://docker.io"
          ],
          "onDemand": true,
          "syncTimeout": "10s",
          "content": [{"prefix": "**"}]
        },
        {
          "urls": [
            "https://ghcr.io"
          ],
          "onDemand": true,
          "syncTimeout": "10s",
          "content": [{"prefix": "**"}]
        },
        {
          "urls": [
            "https://quay.io"
          ],
          "onDemand": true,
          "syncTimeout": "10s",
          "content": [{"prefix": "**"}]
        },
        {
          "urls": [
            "https://registry.k8s.io"
          ],
          "onDemand": true,
          "syncTimeout": "10s",
          "content": [{"prefix": "**"}]
        },
        {
          "urls": [
            "https://docker.elastic.co"
          ],
          "onDemand": true,
          "syncTimeout": "10s",
          "content": [{"prefix": "**"}]
        }
      ]
    }
  }
}

